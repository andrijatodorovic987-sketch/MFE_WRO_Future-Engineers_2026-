    elif search_after_parking:
        return jsonify({"mode": "SEARCHING"})
    return jsonify({"mode": mode})

@app.route('/count_status')
def count_status():
    return jsonify({"count": obstacle_counter})

@app.route('/distance')
def distance_api():
    return jsonify({"distance": last_distance})

@app.route('/set_roi')
def set_roi():
    cut = request.args.get('cut', default=80, type=int)
    cut = max(0, min(180, cut))  # Ograniči između 0 i 180
    params["ROI_BOTTOM_CUT"] = cut
    print(f"✂️ ROI postavljen: odsiječeno {cut} piksela odozdo")
    return jsonify({"status": "ok", "cut": cut})

@app.route('/get_roi')
def get_roi():
    return jsonify({"cut": params["ROI_BOTTOM_CUT"]})

@app.route('/video')
def video():
    return Response(generate_frames(), mimetype='multipart/x-mixed-replace; boundary=frame')

