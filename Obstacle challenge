def generate_frames():
    global running, mode, action_start_time, current_turn_direction
    global initial_turn_direction, detected_color, pid_integral, last_error
    global frame_counter, last_detection_result, last_detection_frame_time
    global obstacle_counter, parking_active, parking_step
    global search_after_parking, search_direction, last_obstacle_color
    global wait_start_time

    last_time = time.time()
    fps_counter = 0
    fps_timer = time.time()
    search_rotate_start = 0

    while True:
        try:
            current_time = time.time()
            dt = current_time - last_time
            last_time = current_time

            if parking_active:
                parking_loop()

            fps_counter += 1
            if current_time - fps_timer >= 1.0:
                fps_counter = 0
                fps_timer = current_time

            ret, frame = cap.read()
            if not ret:
                time.sleep(0.01)
                continue

            # Napravi kopiju za prikaz sa ROI linijom
            display_frame = frame.copy()
            h, w = display_frame.shape[:2]
            cut_from_bottom = params["ROI_BOTTOM_CUT"]

            # Nacrtaj liniju gdje je ROI odsječen
            if cut_from_bottom > 0 and cut_from_bottom < h:
                cv2.line(display_frame, (0, h - cut_from_bottom), (w, h - cut_from_bottom), (0, 255, 255), 2)
                cv2.putText(display_frame, f"ROI CUT: {cut_from_bottom}px", (10, h - cut_from_bottom - 5),
                           cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0, 255, 255), 1)

            frame_counter += 1

            if frame_counter % DETECTION_EVERY_N_FRAMES == 0:
                obj = find_best_object_with_scaling(frame)
                last_detection_result = obj
                last_detection_frame_time = current_time
            else:
                obj = last_detection_result

            dist = get_distance()
            gyro_change = get_gyro_change()
            gyro_raw = gyro_raw_angle
            gyro_parking_change = get_gyro_change_from_parking_zero()

            h_disp, w_disp, _ = display_frame.shape
            cx, cy = w_disp // 2, h_disp // 2

            cv2.circle(display_frame, (cx, cy), 5, (255, 255, 255), -1)

            # ===== SEARCH MODE - traženje prepreke nakon parkinga =====
            if search_after_parking and not parking_active:
                if mode != "SEARCHING":
                    mode = "SEARCHING"
                    # Ako imamo zadnju boju, postavi smjer traženja
                    if last_obstacle_color:
                        if last_obstacle_color == "GREEN":
                            search_direction = "RIGHT"
                            print(f"🔍 SEARCH MODE: Nakon ZELENE, tražim DESNO")
                        elif last_obstacle_color == "RED":
                            search_direction = "LEFT"
                            print(f"🔍 SEARCH MODE: Nakon CRVENE, tražim LIJEVO")

                    # Skreni u smjeru traženja
                    if search_direction == "LEFT":
                        set_servo_turn("LEFT")
                    else:
                        set_servo_turn("RIGHT")
                    time.sleep(0.2)
                    motor_forward(params["SEARCH_SPEED"])
                    reset_gyro_zero()
                    search_rotate_start = time.time()
                    print(f"🔍 SEARCH MODE: Rotiram {'LIJEVO' if search_direction == 'LEFT' else 'DESNO'} i tražim prepreku...")

                # Ako je detektovan objekat, prekini search mode
                if obj:
                    motor_stop()
                    set_servo(params["CENTER"])
                    detected_color = obj[0]
                    last_obstacle_color = detected_color  # ZAPAMTI BOJU ZA SLJEDECI PUT
                    search_after_parking = False
                    running = True
                    mode = "APPROACH"
                    pid_integral = 0
                    last_error = 0
                    obstacle_counter = 0
                    print(f"\n✅ SEARCH MODE: Pronađena prepreka {detected_color}! Nastavljam sa zaobilaženjem...")

                # Ako se okrenuo previše a nema prepreke, stani (sigurnosno)
                elif abs(gyro_change) > 180:
                    motor_stop()
                    search_after_parking = False
                    running = False
                    mode = "WAIT_FOR_OBJECT"
                    print("⚠️ SEARCH MODE: Nema prepreke u krugu od 180°")

            # ===== GLAVNI PROGRAM ZA ZAOBILAŽENJE =====
            elif running and not parking_active and not search_after_parking:
                if mode == "WAIT_FOR_OBJECT":
                    motor_stop()
                    set_servo(params["CENTER"])

                    # Ako je prvi put u WAIT_FOR_OBJECT, zabilježi vrijeme
                    if wait_start_time == 0:
                        wait_start_time = current_time

                    # Provjeri da li je proslo 3 sekunde bez detekcije
                    if current_time - wait_start_time >= params["OBSTACLE_AVOID_TIMEOUT"]:
                        print(f"\n⚠️ Nema prepreke {params['OBSTACLE_AVOID_TIMEOUT']} sekundi! Mjerim udaljenosti...")

                        # Izmjeri udaljenosti lijevo i desno
                        dist_left = get_distance_left()
                        dist_right = get_distance_right()

                        print(f"   📏 Lijeva udaljenost: {dist_left:.1f} cm")
                        print(f"   📏 Desna udaljenost: {dist_right:.1f} cm")

                        # Ako je lijeva udaljenost MANJA od desne, idi DESNO (tamo gdje je veća udaljenost)
                        if dist_left < dist_right:
                            print(f"   🔄 Lijeva je manja ({dist_left:.1f} < {dist_right:.1f}) -> skrećem DESNO")
                            current_turn_direction = "RIGHT"
                            set_servo_turn("RIGHT")
                        else:
                            print(f"   🔄 Desna je manja ({dist_right:.1f} < {dist_left:.1f}) -> skrećem LIJEVO")
                            current_turn_direction = "LEFT"
                            set_servo_turn("LEFT")

                        time.sleep(0.1)
                        motor_forward(params["TURN_SPEED"])
                        mode = "AVOID_OBSTACLE"
                        action_start_time = current_time
                        wait_start_time = 0  # Resetuj timer

                    if obj:
                        detected_color = obj[0]
                        print(f"\n✅ DETEKTOVANO: {detected_color}")
                        mode = "APPROACH"
                        pid_integral = 0
                        last_error = 0
                        wait_start_time = 0  # Resetuj timer
                    time.sleep(0.05)

                elif mode == "APPROACH":
                    if obj and obj[0] == detected_color:
                        target_x = obj[2]
                        error = target_x - cx

                        if abs(error) < params["DEAD_ZONE"]:
                            error = 0
                            pid_integral = 0

                        error = max(-50, min(50, error))

                        if dt > 0 and dt < 0.1:
                            pid_integral += error * dt
                            pid_integral = max(-50, min(50, pid_integral))
                            derivative = (error - last_error) / dt
                        else:
                            derivative = 0

                        servo_correction = (params["PID_KP"] * error) + (params["PID_KI"] * pid_integral) + (params["PID_KD"] * derivative)
                        servo_correction = max(-15, min(15, servo_correction))

                        set_servo(params["CENTER"] + servo_correction)
                        last_error = error

                        if obj[1] is not None:
                            cv2.drawContours(display_frame, [obj[1]], -1, (0, 255, 0) if detected_color == "GREEN" else (0, 0, 255), 2)
                        cv2.line(display_frame, (cx, cy-10), (cx, cy+10), (255, 255, 255), 2)
                        cv2.line(display_frame, (cx-10, cy), (cx+10, cy), (255, 255, 255), 2)
                        cv2.putText(display_frame, f"Err:{error}", (10, 95), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255,255,0), 1)

                        motor_forward()

                        if dist <= params["DIST_THRESHOLD"]:
                            motor_stop()
                            print(f"\n🎯 STIGAO NA {dist:.1f}cm")
                            obstacle_counter += 1
                            print(f"📊 Zaobiđeno prepreka: {obstacle_counter}")

                            if detected_color == "GREEN":
                                initial_turn_direction = "LEFT"
                            else:
                                initial_turn_direction = "RIGHT"

                            current_turn_direction = initial_turn_direction
                            mode = "STOP_AND_RESET"
                            action_start_time = time.time()
                    else:
                        set_servo(params["CENTER"])
                        mode = "WAIT_FOR_OBJECT"
                        wait_start_time = time.time()

                elif mode == "AVOID_OBSTACLE":
                    # Rotiraj u odabranom smjeru
                    if current_time - action_start_time >= params["AVOID_TURN_TIME"]:
                        motor_stop()
                        set_servo(params["CENTER"])
                        mode = "WAIT_FOR_OBJECT"
                        wait_start_time = time.time()
                        print(f"✅ Izbjegavanje završeno, nastavljam traženje...")

                    cv2.putText(display_frame, f"AVOIDING: {current_turn_direction}", (10, 110), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)

                elif mode == "STOP_AND_RESET":
                    if time.time() - action_start_time > params["STOP_TIME"]:
                        reset_gyro_zero()
                        mode = "TURN_FIRST"
                        action_start_time = time.time()
                        print(f"🔄 Prvo skretanje: {current_turn_direction}")
                        set_servo_turn(current_turn_direction)
                        time.sleep(0.1)

                elif mode == "TURN_FIRST":
                    motor_forward(params["TURN_SPEED"])
                    current_change = get_gyro_change()

                    if current_turn_direction == "LEFT":
                        if current_change <= -params["TURN_ANGLE"]:
                            motor_stop()
                            mode = "TURN_FIRST_DONE"
                            action_start_time = time.time()
                            print(f"✅ Skrenuo LIJEVO za {abs(current_change):.1f}°")
                    else:
                        if current_change >= params["TURN_ANGLE"]:
                            motor_stop()
                            mode = "TURN_FIRST_DONE"
                            action_start_time = time.time()
                            print(f"✅ Skrenuo DESNO za {current_change:.1f}°")

                    cv2.putText(display_frame, f"Change: {current_change:.1f}°", (10, 80), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)

                elif mode == "TURN_FIRST_DONE":
                    if time.time() - action_start_time > params["STOP_TIME"]:
                        set_servo(params["CENTER"])
                        time.sleep(0.1)
                        mode = "STRAIGHT_FIRST"
                        action_start_time = time.time()
                        print(f"🚗 Vožnja pravo {params['STRAIGHT_TIME']}s")

                elif mode == "STRAIGHT_FIRST":
                    motor_forward()
                    if time.time() - action_start_time > params["STRAIGHT_TIME"]:
                        motor_stop()
                        mode = "STRAIGHT_FIRST_DONE"
                        action_start_time = time.time()
                        print("⏸️ Vožnja završena")

                elif mode == "STRAIGHT_FIRST_DONE":
                    if time.time() - action_start_time > params["STOP_TIME"]:
                        opposite_dir = "RIGHT" if current_turn_direction == "LEFT" else "LEFT"
                        set_servo_turn(opposite_dir)
                        time.sleep(0.1)
                        mode = "RETURN_TO_ZERO"
                        action_start_time = time.time()
                        print(f"🔄 Vraćam se na 0° (skrećem {opposite_dir})")

                elif mode == "RETURN_TO_ZERO":
                    motor_forward(params["TURN_SPEED"])
                    current_change = get_gyro_change()

                    if abs(current_change) < 3:
                        motor_stop()
                        mode = "RETURN_TO_ZERO_DONE"
                        action_start_time = time.time()
                        print(f"✅ Vratio se na {current_change:.1f}°")

                elif mode == "RETURN_TO_ZERO_DONE":
                    if time.time() - action_start_time > params["STOP_TIME"]:
                        set_servo(params["CENTER"])
                        time.sleep(0.1)

                        if obstacle_counter >= 2:
                            print(f"🎯 DOSTIGNUTO 2 PREPREKE! Krećem u FINALNO SKRETANJE od 75°")
                            mode = "FINAL_TURN"
                            reset_gyro_zero()
                            action_start_time = time.time()
                        else:
                            mode = "CHECK_OBJECT"
                            action_start_time = time.time()
                            print("🔍 Provjeravam ima li prepreke...")

                elif mode == "CHECK_OBJECT":
                    if time.time() - action_start_time > 0.5:
                        if obj:
                            print(f"✅ Ima prepreka! Nastavljam")
                            detected_color = obj[0]
                            mode = "APPROACH"
                        else:
                            # NOVA LOGIKA ZA PRVU PREPREKU (count = 1)
                            if obstacle_counter == 1:
                                front_dist = get_distance()
                                print(f"📏 Prednji senzor: {front_dist:.1f} cm")

                                if front_dist < params["FRONT_DIST_THRESHOLD"]:
                                    # Ako je ispred nas zid ili prepreka, idi LIJEVO polako
                                    print(f"🚨 Prednji senzor je {front_dist:.1f}cm (< {params['FRONT_DIST_THRESHOLD']}cm) - skrećem LIJEVO i tražim prepreku...")
                                    current_turn_direction = "LEFT"
                                    set_servo_turn("LEFT")
                                    time.sleep(0.1)
                                    reset_gyro_zero()
                                    mode = "LEFT_TURN_AFTER_FIRST"
                                    action_start_time = time.time()
                                    motor_forward(params["LEFT_TURN_SPEED"])
                                else:
                                    # Ako je ispred prazno, radi staru logiku (skretanje desno 20°)
                                    print(f"✅ Prednji senzor je {front_dist:.1f}cm (>= {params['FRONT_DIST_THRESHOLD']}cm) - radim staru logiku (skrećem desno 20°)")
                                    current_turn_direction = "RIGHT"
                                    set_servo_turn("RIGHT")
                                    time.sleep(0.1)
                                    reset_gyro_zero()
                                    mode = "SIMPLE_TURN"
                                    action_start_time = time.time()
                            else:
                                # Za count = 0 ili count > 1, radi staru logiku
                                print("❌ Nema prepreke! Rotiram se 20° desno...")
                                current_turn_direction = "RIGHT"
                                set_servo_turn("RIGHT")
                                time.sleep(0.1)
                                reset_gyro_zero()
                                mode = "SIMPLE_TURN"
                                action_start_time = time.time()

                elif mode == "LEFT_TURN_AFTER_FIRST":
                    # Kreće se lijevo i traži prepreku
                    motor_forward(params["LEFT_TURN_SPEED"])

                    # Ako je detektovana prepreka, idi ka njoj
                    if obj:
                        motor_stop()
                        set_servo(params["CENTER"])
                        detected_color = obj[0]
                        last_obstacle_color = detected_color
                        mode = "APPROACH"
                        pid_integral = 0
                        last_error = 0
                        print(f"\n✅ LEFT_TURN: Pronađena prepreka {detected_color}! Nastavljam sa zaobilaženjem...")

                    cv2.putText(display_frame, f"LEFT TURN - trazim prepreku...", (10, 110), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0,255,255), 1)

                elif mode == "SIMPLE_TURN":
                    motor_forward(params["TURN_SPEED"])
                    current_change = get_gyro_change()

                    if current_change >= params["TURN_ANGLE"]:
                        motor_stop()
                        mode = "SIMPLE_TURN_DONE"
                        action_start_time = time.time()
                        print(f"✅ Rotirao za {current_change:.1f}° desno")

                elif mode == "SIMPLE_TURN_DONE":
                    if time.time() - action_start_time > params["STOP_TIME"]:
                        set_servo(params["CENTER"])
                        time.sleep(0.1)
                        mode = "WAIT_FOR_OBJECT"
                        print("🔍 Nastavljam pretragu...\n")

                elif mode == "FINAL_TURN":
                    # PROVJERI DA LI JE DETEKTOVANA PREPREKA TOKOM FINAL_TURN
                    if obj:
                        print(f"\n🎯 DETEKTOVANA PREPREKA TOKOM FINALNOG SKRETANJA! Prekidam final turn i idem ka {obj[0]}")
                        motor_stop()
                        set_servo(params["CENTER"])
                        detected_color = obj[0]
                        mode = "APPROACH"
                        pid_integral = 0
                        last_error = 0
                        obstacle_counter = 0
                        continue  # Preskoči ostatak FINAL_TURN logike

                    motor_forward(params["FINAL_TURN_SPEED"])

                    if params["FINAL_TURN_DIRECTION"] == "LEFT":
                        set_servo(params["FINAL_TURN_SERVO_LEFT"])
                        current_change = get_gyro_change()
                        cv2.putText(display_frame, f"FINAL LEFT: {current_change:.1f}/{-params['FINAL_TURN_ANGLE']}", (10, 110), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0,255,255), 1)

                        if current_change <= -params["FINAL_TURN_ANGLE"]:
                            motor_stop()
                            mode = "FINAL_TURN_DONE"
                            action_start_time = time.time()
                            print(f"✅ Finalno skretanje LIJEVO za {abs(current_change):.1f}°")
                    else:
                        set_servo(params["FINAL_TURN_SERVO_RIGHT"])
                        current_change = get_gyro_change()
                        cv2.putText(display_frame, f"FINAL RIGHT: {current_change:.1f}/{params['FINAL_TURN_ANGLE']}", (10, 110), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0,255,255), 1)

                        if current_change >= params["FINAL_TURN_ANGLE"]:
                            motor_stop()
                            mode = "FINAL_TURN_DONE"
                            action_start_time = time.time()
                            print(f"✅ Finalno skretanje DESNO za {current_change:.1f}°")

                elif mode == "FINAL_TURN_DONE":
                    if time.time() - action_start_time > 0.5:
                        set_servo(params["CENTER"])
                        time.sleep(0.2)
                        obstacle_counter = 0
                        print("🔄 Brojač resetovan na 0. Tražim novu prepreku...")
                        mode = "WAIT_FOR_OBJECT"

                elif mode == "SEARCHING":
                    # Ovdje je search mode - rotira i traži
                    if obj:
                        motor_stop()
                        set_servo(params["CENTER"])
                        detected_color = obj[0]
                        last_obstacle_color = detected_color  # ZAPAMTI BOJU
                        search_after_parking = False
                        mode = "APPROACH"
                        pid_integral = 0
                        last_error = 0
                        obstacle_counter = 0
                        print(f"\n✅ Pronađena prepreka {detected_color}! Nastavljam...")

            # Prikaz info na ekranu
            cv2.putText(display_frame, f"Dist:{dist:.0f}cm", (5, 15), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255,255,255), 1)
            cv2.putText(display_frame, f"ROI Cut: {params['ROI_BOTTOM_CUT']}px", (5, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255,255,0), 1)

            if parking_active:
                cv2.putText(display_frame, f"MODE:PARK-{parking_step}", (5, 45), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)
            elif search_after_parking:
                cv2.putText(display_frame, f"MODE:SEARCHING", (5, 45), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)
            else:
                cv2.putText(display_frame, f"Mode:{mode}", (5, 45), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)

            cv2.putText(display_frame, f"Gyro:{gyro_change:.1f}", (5, 60), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255,255,0), 1)
            cv2.putText(display_frame, f"Count:{obstacle_counter}", (5, 75), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,0), 2)
            cv2.putText(display_frame, f"ParkGyro:{gyro_parking_change:.1f}", (5, 90), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255,255,0), 1)

            _, buffer = cv2.imencode('.jpg', display_frame, [int(cv2.IMWRITE_JPEG_QUALITY), 20])
            yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + buffer.tobytes() + b'\r\n')

        except Exception as e:
            print(f"Frame error: {e}")
            time.sleep(0.01)
            continue

