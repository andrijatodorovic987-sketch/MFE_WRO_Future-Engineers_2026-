@app.route('/start')
def start():
    global running, mode, detected_color, pid_integral, last_error, obstacle_counter, parking_active, search_after_parking, wait_start_time
    if parking_active:
        return "Parking je aktivan, sačekaj da završi"
    running = True
    mode = "WAIT_FOR_OBJECT"
    detected_color = None
    pid_integral = 0
    last_error = 0
    obstacle_counter = 0
    search_after_parking = False
    wait_start_time = 0
    reset_gyro_zero()
    set_servo(params["CENTER"])
    print("\n=== 🤖 ROBOT START ===")
    return "START"

@app.route('/stop')
def stop():
    global running, search_after_parking
    running = False
    search_after_parking = False
    motor_stop()
    print("\n=== 🛑 ROBOT STOP ===")
    return "STOP"

@app.route('/park')
def park():
    global running, parking_active, search_after_parking
    if parking_active:
        return "Parking je već aktivan"
    running = False
    search_after_parking = False
    start_parking()
    return "ISPARKIRAVANJE ZAPOČETO"

