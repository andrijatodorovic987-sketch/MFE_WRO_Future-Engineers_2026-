# ======================
# MOTOR KONTROLA
# ======================
def motor_forward(speed=None):
    if speed is None:
        speed = params["speed"]
    pi.write(params["IN3"], 0)
    pi.write(params["IN4"], 1)
    pi.set_PWM_dutycycle(params["PWM_PIN"], int(speed * 2.55))

def motor_backward(speed=None):
    if speed is None:
        speed = params["speed"]
    pi.write(params["IN3"], 1)
    pi.write(params["IN4"], 0)
    pi.set_PWM_dutycycle(params["PWM_PIN"], int(speed * 2.55))

def motor_stop():
    pi.write(params["IN3"], 0)
    pi.write(params["IN4"], 0)
    pi.set_PWM_dutycycle(params["PWM_PIN"], 0)

# ======================
# SERVO KONTROLA
# ======================
def set_servo(angle):
    global last_servo_angle
    angle += params["SERVO_OFFSET"]
    angle = max(60, min(120, angle))
    pulse = 500 + (angle / 180.0) * 2000
    pi.set_servo_pulsewidth(params["SERVO_PIN"], pulse)
    last_servo_angle = angle

def set_servo_turn(direction):
    angle = params[direction]
    angle += params["SERVO_OFFSET"]
    angle = max(60, min(120, angle))
    pulse = 500 + (angle / 180.0) * 2000
    pi.set_servo_pulsewidth(params["SERVO_PIN"], pulse)

