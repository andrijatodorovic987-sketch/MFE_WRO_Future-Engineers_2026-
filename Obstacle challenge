def search_for_obstacle():
    global mode, search_after_parking, search_direction, running, last_obstacle_color

    if not search_after_parking:
        return

    # Ako imamo zadnju boju, postavi smjer traženja na osnovu nje
    if last_obstacle_color:
        if last_obstacle_color == "GREEN":
            search_direction = "RIGHT"
            print(f"🔍 SEARCH MODE: Nakon zaobilaženja ZELENE, tražim prepreku DESNO")
        elif last_obstacle_color == "RED":
            search_direction = "LEFT"
            print(f"🔍 SEARCH MODE: Nakon zaobilaženja CRVENE, tražim prepreku LIJEVO")
    else:
        # Ako nema zadnje boje, koristi default iz parkinga
        print(f"🔍 SEARCH MODE: Tražim prepreku {'LIJEVO' if search_direction == 'LEFT' else 'DESNO'} (default)")

    # Skreni u smjeru traženja
    if search_direction == "LEFT":
        set_servo_turn("LEFT")
    else:
        set_servo_turn("RIGHT")

    time.sleep(0.2)

    # Lagano se okreći dok ne vidi prepreku
    motor_forward(params["SEARCH_SPEED"])

    # Resetuj gyro za pracenje rotacije
    reset_gyro_zero()
    search_start_time = time.time()

    # Ulazi u poseban mode za traženje
    mode = "SEARCHING"

