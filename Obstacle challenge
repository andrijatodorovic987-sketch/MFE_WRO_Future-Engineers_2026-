def apply_roi(frame):
    """Primjeni ROI - odsiječe donji dio slike"""
    h, w = frame.shape[:2]
    cut_from_bottom = params["ROI_BOTTOM_CUT"]

    if cut_from_bottom > 0 and cut_from_bottom < h:
        # Odsiječemo donji dio
        roi_frame = frame[0:h-cut_from_bottom, :]
        return roi_frame
    return frame

def find_best_object_fast(frame_small):
    hsv = cv2.cvtColor(frame_small, cv2.COLOR_BGR2HSV)

    lower_green = np.array([40, 40, 40])
    upper_green = np.array([80, 255, 255])
    green_mask = cv2.inRange(hsv, lower_green, upper_green)

    lower_red1 = np.array([0, 100, 100])
    upper_red1 = np.array([10, 255, 255])
    lower_red2 = np.array([160, 100, 100])
    upper_red2 = np.array([180, 255, 255])
    red_mask1 = cv2.inRange(hsv, lower_red1, upper_red1)
    red_mask2 = cv2.inRange(hsv, lower_red2, upper_red2)
    red_mask = cv2.bitwise_or(red_mask1, red_mask2)

    green_pixels = cv2.countNonZero(green_mask)
    red_pixels = cv2.countNonZero(red_mask)

    if green_pixels < 80 and red_pixels < 80:
        return None

    if green_pixels > red_pixels:
        mask = green_mask
        color_name = "GREEN"
    else:
        mask = red_mask
        color_name = "RED"

    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if not contours:
        return None

    c = max(contours, key=cv2.contourArea)
    area = cv2.contourArea(c)

    if area > 60:
        x, y, w, h = cv2.boundingRect(c)
        return (color_name, c, x + w//2, y + h//2, area, w)
    return None

def find_best_object_with_scaling(frame_big):
    # PRIMJENI ROI NA ORIGINALNI FREJM
    frame_roi = apply_roi(frame_big)

    if frame_roi is None or frame_roi.shape[0] == 0:
        return None

    frame_small = cv2.resize(frame_roi, (160, 120), interpolation=cv2.INTER_NEAREST)
    result = find_best_object_fast(frame_small)

    if result:
        color_name, contour, cx_small, cy_small, area, w = result
        cx_big = cx_small * 2
        cy_big = cy_small * 2
        if contour is not None and len(contour) > 0:
            contour_scaled = contour * 2
        else:
            contour_scaled = None
        return (color_name, contour_scaled, cx_big, cy_big, area * 4, w * 2)
    return None

