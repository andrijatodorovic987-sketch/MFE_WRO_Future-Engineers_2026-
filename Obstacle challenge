def gyro_reader_thread():
    global gyro_raw_angle, gyro_velocity, gyro_direction, gyro_connected, gyro_last_update

    try:
        ser = serial.Serial(
            port=GYRO_PORT,
            baudrate=GYRO_BAUD,
            timeout=1
        )
        print("✅ Žiroskop povezan!")
        gyro_connected = True
        time.sleep(2)

        while True:
            if ser.in_waiting > 0:
                line = ser.readline().decode('utf-8').strip()

                if line and line != "READY":
                    parts = line.split('|')
                    if len(parts) == 3:
                        try:
                            gyro_raw_angle = float(parts[0])
                            gyro_velocity = float(parts[1])
                            gyro_direction = parts[2]
                            gyro_last_update = time.time()
                        except ValueError:
                            pass
            time.sleep(0.01)

    except serial.SerialException as e:
        print(f"❌ Gyro greška: {e}")
        gyro_connected = False
    except Exception as e:
        print(f"❌ Neočekivana greška: {e}")
        gyro_connected = False

def reset_gyro_zero():
    global gyro_start_angle
    gyro_start_angle = gyro_raw_angle
    print(f"   🎯 Žiroskop resetovan - start: {gyro_start_angle:.1f}°")

def get_gyro_change():
    change = gyro_raw_angle - gyro_start_angle
