def get_distance():
    global last_distance
    try:
        pi.write(params["TRIG"], 0)
        time.sleep(0.05)

        pi.write(params["TRIG"], 1)
        time.sleep(0.00001)
        pi.write(params["TRIG"], 0)

        start = time.time()
        stop = start
        timeout = time.time() + 0.1

        while pi.read(params["ECHO"]) == 0:
            start = time.time()
            if time.time() > timeout:
                return last_distance

        while pi.read(params["ECHO"]) == 1:
            stop = time.time()
            if time.time() > timeout:
                return last_distance

        distance = (stop - start) * 34300 / 2

        if 0 < distance < 500:
            last_distance = distance
            return distance
        else:
            return last_distance

    except Exception:
        return last_distance

